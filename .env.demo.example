# Demo mode uses a deterministic seeded SQLite database and does not require a model API key.
AGENT_FACTORY_DEMO_MODE=true
DB_PATH=packages/server/data/demo.db
EMBEDDING_BACKEND=pseudo
MEMORY_KNOWLEDGE_BRIDGE=false

# Optional: set these to switch from seeded demo data to live agent execution.
# AGENT_FACTORY_BASE_URL=https://your-openai-compatible-endpoint/v1
# AGENT_FACTORY_API_KEY=your-api-key
# AGENT_FACTORY_MODEL=gpt-5.4-mini
