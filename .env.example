# Agent Factory — Environment Variables
# Copy this file to .env and fill in values

# ============ Core ============
PORT=3000
NODE_ENV=development

# ============ Database ============
# SQLite (development) — no config needed, uses ./data/agent-factory.db
# PostgreSQL (production):
# DATABASE_URL=postgres://user:password@localhost:5432/agent_factory
DB_PATH=

# ============ Redis (optional — enables distributed features) ============
# REDIS_URL=redis://localhost:6379

# ============ Execution ============
# EXECUTOR_MODE=local|docker (default: local)
EXECUTOR_MODE=local
# AGENT_DOCKER_IMAGE=agent-factory/sandbox:latest
# CONTAINER_POOL_SIZE=3

# ============ Worker Mode ============
# WORKER_MODE=scheduler|worker|both (default: both)
WORKER_MODE=both

# ============ Authentication ============
# AUTH_MODE=local|oidc (default: local — no auth required)
AUTH_MODE=local
# SESSION_SECRET=change-me-in-production
# API_AUTH_TOKEN=optional-static-token-for-dev

# OIDC (when AUTH_MODE=oidc)
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# ============ CORS ============
# Comma-separated origins (leave empty for permissive in dev)
# CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# ============ Secrets Management ============
# SECRET_PROVIDER=env|vault|aws (default: env)
SECRET_PROVIDER=env
# VAULT_ADDR=http://127.0.0.1:8200
# VAULT_TOKEN=
# AWS_REGION=us-east-1
# AWS_SECRET_PREFIX=agent-factory/

# ============ Myrmecia Model Runtime ============
# New MYRMECIA_* names are preferred; legacy AGENT_FACTORY_* still work as fallbacks.
# MYRMECIA_BASE_URL=https://morninglab.japaneast.cloudapp.azure.com/v1
# MYRMECIA_API_KEY=
# MYRMECIA_MODEL=gpt-5.4-mini
# AGENT_FACTORY_BASE_URL=https://morninglab.japaneast.cloudapp.azure.com/v1   # legacy alias
# AGENT_FACTORY_API_KEY=                                                       # legacy alias
# AGENT_FACTORY_MODEL=gpt-5.4-mini                                             # legacy alias
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ============ Observability ============
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=agent-factory
LOG_LEVEL=debug

# ============ Vector/RAG ============
# VECTOR_BACKEND=memory|pgvector|qdrant (default: memory)
VECTOR_BACKEND=memory
# EMBEDDING_MODEL=text-embedding-3-small
# QDRANT_URL=http://localhost:6333
