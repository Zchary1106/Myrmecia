{
  "name": "agent-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous Agent Orchestration System",
  "scripts": {
    "start:local": "bash scripts/start.sh",
    "dev": "concurrently \"pnpm --filter @agent-factory/server dev\" \"pnpm --filter @agent-factory/dashboard dev\"",
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @agent-factory/server dev",
    "dev:dashboard": "pnpm --filter @agent-factory/dashboard dev",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msgpackr-extract"
    ]
  }
}
